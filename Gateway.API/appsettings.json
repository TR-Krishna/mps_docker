{
  // ═══════════════════════════════════════════════════════════════════════════
  // SE MPS Mysuru — AMI Platform Gateway  |  appsettings.json
  // ═══════════════════════════════════════════════════════════════════════════
  //
  // THIS IS THE SINGLE FILE YOU EDIT TO RECONFIGURE THE GATEWAY.
  // No code changes are ever needed for:
  //   → Adding or removing a downstream microservice
  //   → Changing rate limits (tweak numbers under RateLimiting)
  //   → Rotating the JWT secret (change Jwt.Key — must match UMS)
  //   → Pointing to staging/production services (change Cluster Addresses)
  //   → Making a route public or protected (change AuthorizationPolicy)
  //
  // ARCHITECTURE NOTE:
  //   JWT tokens are ISSUED by UserManagementService (port 5010).
  //   This Gateway only VALIDATES them. The signing key must be identical
  //   in both Gateway/appsettings.json and UserManagementService/appsettings.json.
  //
  // PORT MAP:
  //   5000 → Gateway.API             (all external traffic enters here)
  //   5010 → UserManagementService   (issues JWTs, user management)
  //   5011 → MeterManagementService  (smart meter CRUD + relay control)
  //   5012 → DataCollectionService   (meter readings, profiles)
  //   5013 → EventService            (tamper, outage, system alerts)
  //   5014 → ScheduleService         (data collection schedules)
  //
  // SECURITY: Before any real deployment, move Jwt.Key to:
  //   Local dev  → dotnet user-secrets set "Jwt:Key" "your-key"
  //   Production → environment variable  ASPNETCORE_Jwt__Key=your-key
  // ═══════════════════════════════════════════════════════════════════════════

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },

  // ─── JWT ─────────────────────────────────────────────────────────────────
  // Key must match UserManagementService's Jwt.Key exactly.
  // Minimum 32 characters for HMAC-SHA256.
  "Jwt": {
    "Key":            "SE-MPS-MYS-CHANGE-ME-MINIMUM-32-CHARS!!",
    "Issuer":         "SE-MPS-UMS",
    "Audience":       "SE-MPS-Platform",
    "ExpiryMinutes":  60
  },

  // ─── Rate Limiting ───────────────────────────────────────────────────────
  // All numbers editable here — no recompile needed.
  "RateLimiting": {
    "Global": {
      "PermitLimit":    200,
      "WindowMinutes":  1,
      "QueueLimit":     20
    },
    "Auth": {
      "PermitLimit":    10,
      "WindowMinutes":  1,
      "QueueLimit":     0
    }
  },

  // ─── YARP Reverse Proxy ──────────────────────────────────────────────────
  //
  // AuthorizationPolicy values:
  //   "default"    → requires valid JWT (most routes)
  //   "anonymous"  → no auth required  (login endpoint only)
  //
  // TO ADD A NEW MICROSERVICE:
  //   1. Add one entry under Routes  (path pattern + clusterId)
  //   2. Add one entry under Clusters (clusterId + Address)
  //   Done. No code changes.
  //
  // Transforms: RequestHeadersCopy:true forwards the original Authorization
  // header so downstream services can optionally inspect user claims.
  "ReverseProxy": {
    "Routes": {

      // ── UserManagementService ──────────────────────────────────────────
      "ums-login": {
        "ClusterId": "ums",
        "AuthorizationPolicy": "anonymous",
        "Match": { "Path": "/api/ums/auth/{**catch-all}" },
        "Transforms": [{ "RequestHeadersCopy": "true" }]
      },
      "ums-protected": {
        "ClusterId": "ums",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/ums/{**catch-all}" },
        "Transforms": [{ "RequestHeadersCopy": "true" }]
      },

      // ── MeterManagementService ─────────────────────────────────────────
      "meters": {
        "ClusterId": "meters",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/v1/meters/{**catch-all}" },
        "Transforms": [{ "RequestHeadersCopy": "true" }]
      },

      // ── DataCollectionService ──────────────────────────────────────────
      "data": {
        "ClusterId": "data",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/data/{**catch-all}" },
        "Transforms": [{ "RequestHeadersCopy": "true" }]
      },

      // ── EventService ───────────────────────────────────────────────────
      "events": {
        "ClusterId": "events",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/events/{**catch-all}" },
        "Transforms": [{ "RequestHeadersCopy": "true" }]
      },

      // ── ScheduleService ────────────────────────────────────────────────
      "schedules": {
        "ClusterId": "schedules",
        "AuthorizationPolicy": "default",
        "Match": { "Path": "/api/schedules/{**catch-all}" },
        "Transforms": [{ "RequestHeadersCopy": "true" }]
      }

    },

    "Clusters": {
      "ums":       { "Destinations": { "d1": { "Address": "http://localhost:5010" } } },
      "meters":    { "Destinations": { "d1": { "Address": "http://localhost:5011" } } },
      "data":      { "Destinations": { "d1": { "Address": "http://localhost:5012" } } },
      "events":    { "Destinations": { "d1": { "Address": "http://localhost:5013" } } },
      "schedules": { "Destinations": { "d1": { "Address": "http://localhost:5014" } } }
    }
  },

  "AllowedHosts": "*"
}
